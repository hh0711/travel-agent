LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional OpenAI fallback
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5-mini

# China Weather / WeatherDT.
# Docs: http://www.weatherdt.com/help.html#jksm
# API format: http://api.weatherdt.com/common/?area=<station_id>&type=forecast|observe|alarm|air&key=<your_key>
WEATHERDT_URL=http://api.weatherdt.com/common/
WEATHERDT_METHOD=GET
WEATHERDT_AREA_PARAM=area
WEATHERDT_TYPE_PARAM=type
WEATHERDT_KEY_PARAM=key
WEATHERDT_TYPE=forecast|observe|alarm|air
WEATHERDT_KEY=your_weatherdt_key
WEATHERDT_TIMEOUT=10
# WeatherDT requires station IDs, not city names. Add the cities your app will use.
# Example station IDs must be checked against your WeatherDT authorized station table.
WEATHERDT_AREA_MAP_JSON={"北京":"101010100","上海":"101020100","苏州":"101190401"}
# Optional fallback station when destination is not in WEATHERDT_AREA_MAP_JSON.
WEATHERDT_DEFAULT_AREA=

# Meituan Travel Skill. The downloaded Skill describes the runtime;
# actual calls use the mttravel CLI from @meituan-travel/travel-cli.
MEITUAN_SKILL_MODE=cli
MEITUAN_SKILL_ID=12
MEITUAN_TRAVEL_CLI=mttravel.cmd
MEITUAN_DEFAULT_CITY=北京
MEITUAN_SKILL_ACCESS_TOKEN=
MEITUAN_SKILL_LIMIT=8
MEITUAN_SKILL_TIMEOUT=150

# Legacy / optional adapters. Leave empty when using mttravel CLI.
MEITUAN_SKILL_COMMAND_JSON=
MEITUAN_SKILL_URL=
MEITUAN_SKILL_METHOD=POST
MEITUAN_SKILL_TOOL_PARAM=tool
MEITUAN_SKILL_INPUT_PARAM=input
MEITUAN_TRAVEL_ASSISTANT_TOOL=travel_assistant
MEITUAN_RESTAURANT_TOOL=
MEITUAN_HOTEL_TOOL=
MEITUAN_SKILL_AUTH_SCHEME=Bearer

# Xiaohongshu authorized search API. Do not use page scraping.
XHS_SEARCH_URL=
XHS_METHOD=GET
XHS_QUERY_PARAM=keyword
XHS_LIMIT_PARAM=limit
XHS_ACCESS_TOKEN=
