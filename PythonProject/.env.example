LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional OpenAI fallback
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5-mini

# Moji Weather. Use the endpoint and auth fields from your Moji Weather contract.
MOJI_WEATHER_URL=
MOJI_METHOD=GET
MOJI_CITY_PARAM=city
MOJI_DAYS_PARAM=days
MOJI_API_KEY=
MOJI_KEY_PARAM=key
# MOJI_ACCESS_TOKEN=your_moji_access_token
# MOJI_AUTH_SCHEME=Bearer
# MOJI_KEY_HEADER=x-api-key

# Meituan Travel Skill. The downloaded Skill describes the runtime;
# actual calls use the mttravel CLI from @meituan-travel/travel-cli.
MEITUAN_SKILL_MODE=cli
MEITUAN_SKILL_ID=12
MEITUAN_TRAVEL_CLI=mttravel.cmd
MEITUAN_DEFAULT_CITY=北京
MEITUAN_SKILL_ACCESS_TOKEN=
MEITUAN_SKILL_LIMIT=8
MEITUAN_SKILL_TIMEOUT=150

# Legacy / optional adapters. Leave empty when using mttravel CLI.
MEITUAN_SKILL_COMMAND_JSON=
MEITUAN_SKILL_URL=
MEITUAN_SKILL_METHOD=POST
MEITUAN_SKILL_TOOL_PARAM=tool
MEITUAN_SKILL_INPUT_PARAM=input
MEITUAN_TRAVEL_ASSISTANT_TOOL=travel_assistant
MEITUAN_RESTAURANT_TOOL=
MEITUAN_HOTEL_TOOL=
MEITUAN_SKILL_AUTH_SCHEME=Bearer

# Xiaohongshu authorized search API. Do not use page scraping.
XHS_SEARCH_URL=
XHS_METHOD=GET
XHS_QUERY_PARAM=keyword
XHS_LIMIT_PARAM=limit
XHS_ACCESS_TOKEN=
